{
  "name": "@sbb-lost-found/api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for SBB Lost and Found system",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sbb-lost-found/types": "file:../../shared/types",
    "express": "^4.18.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "http-proxy-middleware": "^2.0.6",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "typescript": "^5.0.0",
    "tsx": "^3.12.0",
    "nodemon": "^3.0.0"
  }
}